---
rhel10_vm_bootstrap:
  runtime_root: /var/lib/stakkr/rhel10-vms

rhel10_vms:
  - name: rhel10-admin
    domain: stakkr.lan
    role: bastion
    driver: local-libvirt
    source_image: /var/lib/libvirt/images/rhel-10.1.qcow2
    source_image_format: qcow2
    disk_path: /var/lib/libvirt/images/rhel10-admin.qcow2
    disk_format: qcow2
    osinfo: rhel10.1
    provisioning:
      rebuild_disk_from_image: false
      recreate_domain: false
    boot:
      firmware: uefi
      machine: q35
      cpu_model: host-passthrough
      tpm_enabled: false
    resources:
      memory_mb: 8192
      vcpus: 2
    stakkr:
      enabled: false
      tier: silver
      iothreads: 0
    network:
      attachment_type: bridge
      bridge_name: bridge0
      libvirt_network: ""
      libvirt_portgroup: ""
      model: virtio
      interface_name: eth0
      mac_address: "52:54:00:50:10:01"
      ipv4_address: 192.168.1.230
      prefix_length: 24
      gateway: 192.168.1.1
      dns_servers:
        - 192.168.1.142
        - 192.168.1.242
    access:
      admin_user: cloud-user
      admin_password: "{{ lab_default_password | default('') }}"
      ssh_private_key_file: "{{ lookup('env', 'HOME') + '/.ssh/id_ed25519' }}"
      lock_password: false
      ssh_password_auth: false
      ssh_authorized_keys: >-
        {{
          [lab_operator_ssh_public_key | default('')]
          | reject('equalto', '')
          | list
        }}
    subscription:
      enabled: false
      activation_key: "{{ lab_rhsm.activation_key | default('') }}"
      organization_id: "{{ lab_rhsm.organization_id | default('') }}"
      username: "{{ lab_rhsm.username | default('') }}"
      password: "{{ lab_rhsm.password | default('') }}"
      server_hostname: "{{ lab_rhsm.server_hostname | default('') }}"
    cloud_init:
      runcmd: []

  - name: rhel10-app
    domain: stakkr.lan
    role: app
    driver: local-libvirt
    source_image: /var/lib/libvirt/images/rhel-10.1.qcow2
    source_image_format: qcow2
    disk_path: /var/lib/libvirt/images/rhel10-app.qcow2
    disk_format: qcow2
    osinfo: rhel10.1
    provisioning:
      rebuild_disk_from_image: false
      recreate_domain: false
    boot:
      firmware: uefi
      machine: q35
      cpu_model: host-passthrough
      tpm_enabled: false
    resources:
      memory_mb: 4096
      vcpus: 2
    stakkr:
      enabled: false
      tier: bronze
      iothreads: 0
    network:
      attachment_type: bridge
      bridge_name: bridge0
      libvirt_network: ""
      libvirt_portgroup: ""
      model: virtio
      interface_name: eth0
      mac_address: "52:54:00:50:10:02"
      ipv4_address: 192.168.1.231
      prefix_length: 24
      gateway: 192.168.1.1
      dns_servers:
        - 192.168.1.142
        - 192.168.1.242
    access:
      admin_user: cloud-user
      admin_password: "{{ lab_default_password | default('') }}"
      ssh_private_key_file: "{{ lookup('env', 'HOME') + '/.ssh/id_ed25519' }}"
      lock_password: false
      ssh_password_auth: false
      ssh_authorized_keys: >-
        {{
          [lab_operator_ssh_public_key | default('')]
          | reject('equalto', '')
          | list
        }}
    subscription:
      enabled: false
      activation_key: "{{ lab_rhsm.activation_key | default('') }}"
      organization_id: "{{ lab_rhsm.organization_id | default('') }}"
      username: "{{ lab_rhsm.username | default('') }}"
      password: "{{ lab_rhsm.password | default('') }}"
      server_hostname: "{{ lab_rhsm.server_hostname | default('') }}"
    cloud_init:
      runcmd:
        - [ systemctl, enable, --now, cockpit.socket ]
