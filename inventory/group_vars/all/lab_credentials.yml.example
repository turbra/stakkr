---
# Copy this file to `lab_credentials.yml`, then encrypt it with ansible-vault:
#
#   cp inventory/group_vars/all/lab_credentials.yml.example \
#      inventory/group_vars/all/lab_credentials.yml
#   ansible-vault encrypt inventory/group_vars/all/lab_credentials.yml
#
# The encrypted `lab_credentials.yml` is intentionally ignored by Git.

lab_default_password: CHANGEME
lab_operator_ssh_public_key: "ssh-ed25519 AAAA... operator@workstation"

# Optional RHSM secrets can also live here instead of tracked files.
lab_rhsm_activation_key: CHANGEME
lab_rhsm_organization_id: CHANGEME
lab_rhsm_username: ""
lab_rhsm_password: ""
lab_rhsm_server_hostname: ""
