{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {"type": "grafana",    "id": "grafana",    "name": "Grafana",    "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "stat",       "name": "Stat",       "version": ""},
    {"type": "panel", "id": "timeseries", "name": "Time series","version": ""},
    {"type": "panel", "id": "bargauge",   "name": "Bar gauge",  "version": ""},
    {"type": "panel", "id": "gauge",      "name": "Gauge",      "version": ""}
  ],
  "description": "Stakkr KVM hypervisor: memory oversubscription, CPU pool topology, KSM/zram efficiency, per-domain breakdown",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["stakkr", "kvm", "calabi"],
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "browser",
  "title": "Stakkr Observer — KVM Hypervisor",
  "uid": "stakkr-observer-mvp",
  "version": 2,
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "refresh": 1,
        "hide": 0
      },
      {
        "name": "host",
        "label": "Host",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "definition": "label_values(calabi_observer_up, host)",
        "query": {"query": "label_values(calabi_observer_up, host)", "refId": "A"},
        "refresh": 2,
        "sort": 1,
        "multi": false,
        "includeAll": false,
        "hide": 0
      }
    ]
  },
  "panels": [

    { "type": "row", "id": 100, "title": "Overview", "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0} },

    {
      "type": "stat", "id": 1, "title": "Observer Status",
      "gridPos": {"h": 4, "w": 3, "x": 0, "y": 1},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "short", "mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red", "index": 0}, "1": {"text": "UP", "color": "green", "index": 1}}}], "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}}},
      "targets": [{"expr": "calabi_observer_up{host=~\"$host\"}", "legendFormat": "status", "instant": true}]
    },
    {
      "type": "stat", "id": 2, "title": "Collect Error",
      "gridPos": {"h": 4, "w": 3, "x": 3, "y": 1},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "short", "mappings": [{"type": "value", "options": {"0": {"text": "OK", "color": "green", "index": 0}, "1": {"text": "FAIL", "color": "red", "index": 1}}}], "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}}},
      "targets": [{"expr": "calabi_observer_collect_error{host=~\"$host\"}", "legendFormat": "error", "instant": true}]
    },
    {
      "type": "stat", "id": 3, "title": "Host Memory",
      "gridPos": {"h": 4, "w": 3, "x": 6, "y": 1},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "bytes", "color": {"mode": "fixed", "fixedColor": "blue"}, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}},
      "targets": [{"expr": "calabi_memory_memtotal_bytes{host=~\"$host\"}", "legendFormat": "total", "instant": true}]
    },
    {
      "type": "stat", "id": 4, "title": "Memory Available",
      "gridPos": {"h": 4, "w": 3, "x": 9, "y": 1},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "percentunit", "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "orange", "value": 0.1}, {"color": "green", "value": 0.25}]}}},
      "targets": [{"expr": "calabi_memory_memavailable_bytes{host=~\"$host\"} / calabi_memory_memtotal_bytes{host=~\"$host\"}", "legendFormat": "available%", "instant": true}]
    },
    {
      "type": "stat", "id": 5, "title": "Memory Overcommit",
      "gridPos": {"h": 4, "w": 3, "x": 12, "y": 1},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 2, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1.2}, {"color": "red", "value": 1.5}]}}},
      "targets": [{"expr": "calabi_guest_memory_committed_bytes{host=~\"$host\"} / calabi_memory_memtotal_bytes{host=~\"$host\"}", "legendFormat": "ratio", "instant": true}]
    },
    {
      "type": "stat", "id": 6, "title": "vCPU Overcommit",
      "gridPos": {"h": 4, "w": 3, "x": 15, "y": 1},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 4}, {"color": "red", "value": 8}]}}},
      "targets": [{"expr": "calabi_guest_vcpus{host=~\"$host\"} / calabi_host_cpu_count{host=~\"$host\"}", "legendFormat": "ratio", "instant": true}]
    },
    {
      "type": "stat", "id": 7, "title": "KSM Saved",
      "gridPos": {"h": 4, "w": 3, "x": 18, "y": 1},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "bytes", "color": {"mode": "fixed", "fixedColor": "teal"}, "thresholds": {"mode": "absolute", "steps": [{"color": "teal", "value": null}]}}},
      "targets": [{"expr": "calabi_ksm_estimated_saved_bytes{host=~\"$host\"}", "legendFormat": "KSM saved", "instant": true}]
    },
    {
      "type": "stat", "id": 8, "title": "zram Saved",
      "gridPos": {"h": 4, "w": 3, "x": 21, "y": 1},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "bytes", "color": {"mode": "fixed", "fixedColor": "purple"}, "thresholds": {"mode": "absolute", "steps": [{"color": "purple", "value": null}]}}},
      "targets": [{"expr": "calabi_zram_estimated_saved_bytes_total{host=~\"$host\"}", "legendFormat": "zram saved", "instant": true}]
    },

    { "type": "row", "id": 101, "title": "CPU", "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5} },

    {
      "type": "timeseries", "id": 10, "title": "Host CPU Usage",
      "gridPos": {"h": 8, "w": 16, "x": 0, "y": 6},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"tooltip": {"mode": "multi", "sort": "desc"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1, "custom": {"lineWidth": 1, "fillOpacity": 12}}},
      "targets": [
        {"expr": "rate(calabi_host_cpu_user_ticks{host=~\"$host\"}[$__rate_interval]) / (rate(calabi_host_cpu_user_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_nice_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_system_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_idle_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_iowait_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_irq_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_softirq_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_steal_ticks{host=~\"$host\"}[$__rate_interval]))", "legendFormat": "user"},
        {"expr": "rate(calabi_host_cpu_system_ticks{host=~\"$host\"}[$__rate_interval]) / (rate(calabi_host_cpu_user_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_nice_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_system_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_idle_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_iowait_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_irq_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_softirq_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_steal_ticks{host=~\"$host\"}[$__rate_interval]))", "legendFormat": "system"},
        {"expr": "rate(calabi_host_cpu_iowait_ticks{host=~\"$host\"}[$__rate_interval]) / (rate(calabi_host_cpu_user_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_nice_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_system_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_idle_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_iowait_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_irq_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_softirq_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_steal_ticks{host=~\"$host\"}[$__rate_interval]))", "legendFormat": "iowait"},
        {"expr": "rate(calabi_host_cpu_steal_ticks{host=~\"$host\"}[$__rate_interval]) / (rate(calabi_host_cpu_user_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_nice_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_system_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_idle_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_iowait_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_irq_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_softirq_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_steal_ticks{host=~\"$host\"}[$__rate_interval]))", "legendFormat": "steal"},
        {"expr": "rate(calabi_host_cpu_softirq_ticks{host=~\"$host\"}[$__rate_interval]) / (rate(calabi_host_cpu_user_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_nice_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_system_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_idle_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_iowait_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_irq_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_softirq_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_steal_ticks{host=~\"$host\"}[$__rate_interval]))", "legendFormat": "softirq"},
        {"expr": "rate(calabi_host_cpu_idle_ticks{host=~\"$host\"}[$__rate_interval]) / (rate(calabi_host_cpu_user_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_nice_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_system_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_idle_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_iowait_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_irq_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_softirq_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_host_cpu_steal_ticks{host=~\"$host\"}[$__rate_interval]))", "legendFormat": "idle"}
      ]
    },
    {
      "type": "bargauge", "id": 11, "title": "CPU Pool Sizes (logical CPUs)",
      "gridPos": {"h": 4, "w": 8, "x": 16, "y": 6},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "horizontal", "displayMode": "gradient", "valueMode": "color"},
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}},
      "targets": [{"expr": "calabi_cpu_pool_size{host=~\"$host\"}", "legendFormat": "{{pool}}", "instant": true}]
    },
    {
      "type": "timeseries", "id": 12, "title": "Memory Management Thread CPU Cost",
      "gridPos": {"h": 4, "w": 8, "x": 16, "y": 10},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "custom": {"lineWidth": 1, "fillOpacity": 10}}},
      "targets": [{"expr": "rate(calabi_kernel_thread_cpu_seconds{host=~\"$host\"}[$__rate_interval])", "legendFormat": "{{thread}}"}]
    },
    {
      "type": "timeseries", "id": 13, "title": "Per-CPU Busy % (all cores)",
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 14},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"tooltip": {"mode": "multi", "sort": "desc"}, "legend": {"displayMode": "list", "placement": "right"}},
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1, "custom": {"lineWidth": 1, "fillOpacity": 0}}},
      "targets": [{
        "expr": "1 - (rate(calabi_cpu_idle_ticks{host=~\"$host\"}[$__rate_interval]) / (rate(calabi_cpu_user_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_cpu_nice_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_cpu_system_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_cpu_idle_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_cpu_iowait_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_cpu_irq_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_cpu_softirq_ticks{host=~\"$host\"}[$__rate_interval])+rate(calabi_cpu_steal_ticks{host=~\"$host\"}[$__rate_interval])))",
        "legendFormat": "{{cpu}}"
      }]
    },
    {
      "type": "timeseries", "id": 14, "title": "Per-CPU Frequency (MHz)",
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 14},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"tooltip": {"mode": "multi", "sort": "desc"}, "legend": {"displayMode": "list", "placement": "right"}},
      "fieldConfig": {"defaults": {"unit": "none", "custom": {"lineWidth": 1, "fillOpacity": 0}, "decimals": 0}},
      "targets": [{"expr": "calabi_cpu_frequency_mhz{host=~\"$host\"}", "legendFormat": "{{cpu}}"}]
    },

    { "type": "row", "id": 102, "title": "Memory", "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 21} },

    {
      "type": "timeseries", "id": 20, "title": "Memory Waterfall",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 22},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"tooltip": {"mode": "multi", "sort": "desc"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "bytes", "custom": {"lineWidth": 1, "fillOpacity": 8}}},
      "targets": [
        {"expr": "calabi_memory_memtotal_bytes{host=~\"$host\"}", "legendFormat": "total"},
        {"expr": "calabi_guest_memory_committed_bytes{host=~\"$host\"}", "legendFormat": "guest committed"},
        {"expr": "calabi_memory_memavailable_bytes{host=~\"$host\"}", "legendFormat": "available"},
        {"expr": "calabi_memory_active_bytes{host=~\"$host\"}", "legendFormat": "active"},
        {"expr": "calabi_memory_inactive_bytes{host=~\"$host\"}", "legendFormat": "inactive"},
        {"expr": "calabi_memory_cached_bytes{host=~\"$host\"}", "legendFormat": "cached"},
        {"expr": "calabi_memory_buffers_bytes{host=~\"$host\"}", "legendFormat": "buffers"},
        {"expr": "calabi_memory_memfree_bytes{host=~\"$host\"}", "legendFormat": "free"}
      ]
    },
    {
      "type": "timeseries", "id": 21, "title": "Memory Components",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 22},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"tooltip": {"mode": "multi", "sort": "desc"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {"defaults": {"unit": "bytes", "custom": {"lineWidth": 1, "fillOpacity": 6}}},
      "targets": [
        {"expr": "calabi_memory_anonpages_bytes{host=~\"$host\"}", "legendFormat": "AnonPages (anon dirty)"},
        {"expr": "calabi_memory_slab_bytes{host=~\"$host\"}", "legendFormat": "Slab (kernel)"},
        {"expr": "calabi_memory_kreclaimable_bytes{host=~\"$host\"}", "legendFormat": "KReclaimable"},
        {"expr": "calabi_memory_shmem_bytes{host=~\"$host\"}", "legendFormat": "Shmem (tmpfs)"},
        {"expr": "calabi_memory_pagetables_bytes{host=~\"$host\"}", "legendFormat": "PageTables"},
        {"expr": "calabi_memory_kernelstack_bytes{host=~\"$host\"}", "legendFormat": "KernelStack"},
        {"expr": "calabi_memory_swapcached_bytes{host=~\"$host\"}", "legendFormat": "SwapCached"}
      ]
    },
    {
      "type": "bargauge", "id": 22, "title": "Domain Memory Committed",
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 30},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "horizontal", "displayMode": "gradient", "valueMode": "color"},
      "fieldConfig": {"defaults": {"unit": "bytes", "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}},
      "targets": [{"expr": "calabi_domain_memory_bytes{host=~\"$host\"}", "legendFormat": "{{domain}} ({{tier}})", "instant": true}]
    },
    {
      "type": "bargauge", "id": 23, "title": "Domain vCPUs",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 30},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "horizontal", "displayMode": "gradient", "valueMode": "color"},
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 8}, {"color": "red", "value": 16}]}}},
      "targets": [{"expr": "calabi_domain_vcpus{host=~\"$host\"}", "legendFormat": "{{domain}} ({{tier}})", "instant": true}]
    },

    { "type": "row", "id": 103, "title": "KSM — Kernel Samepage Merging", "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 36} },

    {
      "type": "stat", "id": 30, "title": "KSM Run State",
      "gridPos": {"h": 3, "w": 4, "x": 0, "y": 37},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "short", "mappings": [{"type": "value", "options": {"0": {"text": "STOPPED", "color": "red", "index": 0}, "1": {"text": "RUNNING", "color": "green", "index": 1}, "2": {"text": "ADVISORY", "color": "orange", "index": 2}}}], "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}}},
      "targets": [{"expr": "calabi_ksm_run{host=~\"$host\"}", "legendFormat": "state", "instant": true}]
    },
    {
      "type": "stat", "id": 31, "title": "KSM Sharing Density",
      "gridPos": {"h": 3, "w": 4, "x": 4, "y": 37},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "orange", "value": 1.5}, {"color": "green", "value": 2}]}}},
      "targets": [{"expr": "calabi_ksm_pages_sharing{host=~\"$host\"} / calabi_ksm_pages_shared{host=~\"$host\"}", "legendFormat": "sharing:shared", "instant": true}]
    },
    {
      "type": "stat", "id": 32, "title": "KSM Scan Interval",
      "gridPos": {"h": 3, "w": 4, "x": 8, "y": 37},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "ms", "color": {"mode": "fixed", "fixedColor": "blue"}, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}},
      "targets": [{"expr": "calabi_ksm_sleep_millisecs{host=~\"$host\"}", "legendFormat": "sleep_ms", "instant": true}]
    },
    {
      "type": "stat", "id": 33, "title": "KSM Pages/Scan",
      "gridPos": {"h": 3, "w": 4, "x": 12, "y": 37},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "fixed", "fixedColor": "blue"}, "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}}},
      "targets": [{"expr": "calabi_ksm_pages_to_scan{host=~\"$host\"}", "legendFormat": "pages/scan", "instant": true}]
    },
    {
      "type": "stat", "id": 34, "title": "KSM Full Scans",
      "gridPos": {"h": 3, "w": 4, "x": 16, "y": 37},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "fixed", "fixedColor": "teal"}, "thresholds": {"mode": "absolute", "steps": [{"color": "teal", "value": null}]}}},
