        {"expr": "calabi_ksm_pages_unshared{host=~\"$host\"}", "legendFormat": "unshared (checked, not merged)"},
        {"expr": "calabi_ksm_pages_volatile{host=~\"$host\"}", "legendFormat": "volatile (changed during scan)"},
        {"expr": "calabi_ksm_estimated_saved_bytes{host=~\"$host\"}", "legendFormat": "estimated saved"}
