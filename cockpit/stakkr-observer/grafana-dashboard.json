      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "fieldConfig": {
        "defaults": {"unit": "bytes", "custom": {"lineWidth": 1, "fillOpacity": 6}},
        "overrides": [{"matcher": {"id": "byName", "options": "ksmd CPU%"}, "properties": [{"id": "unit", "value": "percentunit"}, {"id": "custom.axisPlacement", "value": "right"}]}]
      },
      "targets": [
        {"expr": "calabi_ksm_estimated_saved_bytes{host=~\"$host\"}", "legendFormat": "estimated saved"},
