        "defaults": {"unit": "bytes", "custom": {"lineWidth": 1, "fillOpacity": 8}},
        "overrides": [{"matcher": {"id": "byName", "options": "compression ratio"}, "properties": [{"id": "unit", "value": "short"}, {"id": "custom.axisPlacement", "value": "right"}, {"id": "custom.fillOpacity", "value": 0}]}]
