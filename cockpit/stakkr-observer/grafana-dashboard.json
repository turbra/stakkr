{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "bargauge", "name": "Bar gauge", "version": ""}
  ],
  "description": "Stakkr KVM hypervisor: memory oversubscription, CPU tier breakdown, KSM/zram efficiency",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["stakkr", "kvm", "calabi"],
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "browser",
  "title": "Stakkr Observer — KVM Hypervisor",
  "uid": "stakkr-observer-mvp",
  "version": 1,
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Datasource",
        "type": "datasource",
        "pluginId": "prometheus",
        "refresh": 1,
        "hide": 0
      },
      {
        "name": "host",
        "label": "Host",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "definition": "label_values(calabi_observer_up, host)",
        "query": {"query": "label_values(calabi_observer_up, host)", "refId": "A"},
        "refresh": 2,
        "sort": 1,
        "multi": false,
        "includeAll": false,
        "hide": 0
      }
    ]
  },
  "panels": [

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "title": "Overview",
      "type": "row"
    },

    {
      "type": "stat",
      "id": 1,
      "title": "Observer Status",
      "gridPos": {"h": 3, "w": 4, "x": 0, "y": 1},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {"type": "value", "options": {"0": {"text": "DOWN", "color": "red", "index": 0}, "1": {"text": "UP", "color": "green", "index": 1}}}
          ],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}
        }
      },
      "targets": [{"expr": "calabi_observer_up{host=~\"$host\"}", "legendFormat": "status", "instant": true}]
    },

    {
      "type": "stat",
      "id": 2,
      "title": "Host Memory",
      "gridPos": {"h": 3, "w": 4, "x": 4, "y": 1},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"colorMode": "value", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {"mode": "fixed", "fixedColor": "blue"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "blue", "value": null}]}
        }
      },
      "targets": [{"expr": "calabi_memory_memtotal_bytes{host=~\"$host\"}", "legendFormat": "total", "instant": true}]
    },

    {
      "type": "stat",
      "id": 3,
      "title": "Memory Available",
      "gridPos": {"h": 3, "w": 4, "x": 8, "y": 1},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "orange", "value": 0.1}, {"color": "green", "value": 0.25}]}
        }
      },
      "targets": [{"expr": "calabi_memory_memavailable_bytes{host=~\"$host\"} / calabi_memory_memtotal_bytes{host=~\"$host\"}", "legendFormat": "available%", "instant": true}]
    },

    {
      "type": "stat",
      "id": 4,
      "title": "Memory Overcommit",
      "gridPos": {"h": 3, "w": 4, "x": 12, "y": 1},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1.2}, {"color": "red", "value": 1.5}]}
        }
      },
      "targets": [{"expr": "calabi_guest_memory_committed_bytes{host=~\"$host\"} / calabi_memory_memtotal_bytes{host=~\"$host\"}", "legendFormat": "ratio", "instant": true}]
    },

    {
      "type": "stat",
      "id": 5,
      "title": "vCPU Overcommit",
      "gridPos": {"h": 3, "w": 4, "x": 16, "y": 1},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"colorMode": "background", "graphMode": "none", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 4}, {"color": "red", "value": 8}]}
        }
      },
      "targets": [{"expr": "calabi_guest_vcpus{host=~\"$host\"} / calabi_host_cpu_count{host=~\"$host\"}", "legendFormat": "ratio", "instant": true}]
    },

    {
      "type": "stat",
      "id": 6,
      "title": "KSM Saved",
      "gridPos": {"h": 3, "w": 4, "x": 20, "y": 1},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {"mode": "fixed", "fixedColor": "teal"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "teal", "value": null}]}
        }
      },
      "targets": [{"expr": "calabi_ksm_estimated_saved_bytes{host=~\"$host\"}", "legendFormat": "KSM saved", "instant": true}]
    },

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 4},
      "id": 101,
      "title": "Memory",
      "type": "row"
    },

    {
      "type": "timeseries",
      "id": 10,
      "title": "Host Memory Waterfall",
      "gridPos": {"h": 8, "w": 16, "x": 0, "y": 5},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {"lineWidth": 1, "fillOpacity": 8, "spanNulls": false}
        }
      },
      "targets": [
        {"expr": "calabi_memory_memtotal_bytes{host=~\"$host\"}", "legendFormat": "total"},
        {"expr": "calabi_memory_memavailable_bytes{host=~\"$host\"}", "legendFormat": "available"},
        {"expr": "calabi_memory_memfree_bytes{host=~\"$host\"}", "legendFormat": "free"},
        {"expr": "calabi_memory_cached_bytes{host=~\"$host\"}", "legendFormat": "cached"},
        {"expr": "calabi_memory_buffers_bytes{host=~\"$host\"}", "legendFormat": "buffers"},
        {"expr": "calabi_memory_active_bytes{host=~\"$host\"}", "legendFormat": "active"},
        {"expr": "calabi_memory_inactive_bytes{host=~\"$host\"}", "legendFormat": "inactive"},
        {"expr": "calabi_memory_slab_bytes{host=~\"$host\"}", "legendFormat": "slab"},
        {"expr": "calabi_guest_memory_committed_bytes{host=~\"$host\"}", "legendFormat": "guest committed"}
      ]
    },

    {
      "type": "timeseries",
      "id": 11,
      "title": "Swap Usage",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 5},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {"lineWidth": 1, "fillOpacity": 10}
        }
      },
      "targets": [
        {"expr": "calabi_swap_used_bytes_total{host=~\"$host\"}", "legendFormat": "total used"},
        {"expr": "calabi_swap_used_bytes{host=~\"$host\"}", "legendFormat": "{{device}}"},
        {"expr": "calabi_memory_swapcached_bytes{host=~\"$host\"}", "legendFormat": "swap cached"}
      ]
    },

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 13},
      "id": 102,
      "title": "KSM / zram",
      "type": "row"
    },

    {
      "type": "timeseries",
      "id": 20,
      "title": "KSM Page Sharing",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"lineWidth": 1, "fillOpacity": 8}
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "estimated saved"}, "properties": [{"id": "unit", "value": "bytes"}, {"id": "custom.axisPlacement", "value": "right"}]}
        ]
      },
      "targets": [
        {"expr": "calabi_ksm_pages_sharing{host=~\"$host\"}", "legendFormat": "sharing (consumers)"},
        {"expr": "calabi_ksm_pages_shared{host=~\"$host\"}", "legendFormat": "shared (unique pages)"},
        {"expr": "calabi_ksm_pages_unshared{host=~\"$host\"}", "legendFormat": "unshared (checked)"},
        {"expr": "calabi_ksm_pages_volatile{host=~\"$host\"}", "legendFormat": "volatile"},
        {"expr": "calabi_ksm_estimated_saved_bytes{host=~\"$host\"}", "legendFormat": "estimated saved"}
      ]
    },

    {
      "type": "timeseries",
      "id": 21,
      "title": "zram Compression",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {"lineWidth": 1, "fillOpacity": 8}
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "compression ratio"}, "properties": [{"id": "unit", "value": "short"}, {"id": "custom.axisPlacement", "value": "right"}]}
        ]
      },
      "targets": [
        {"expr": "sum(calabi_zram_mm_orig_data_size{host=~\"$host\"})", "legendFormat": "original data"},
        {"expr": "sum(calabi_zram_mm_compr_data_size{host=~\"$host\"})", "legendFormat": "compressed data"},
        {"expr": "sum(calabi_zram_mem_used_bytes{host=~\"$host\"})", "legendFormat": "mem used"},
        {"expr": "calabi_zram_estimated_saved_bytes_total{host=~\"$host\"}", "legendFormat": "estimated saved"},
        {"expr": "sum(calabi_zram_mm_compr_data_size{host=~\"$host\"}) / sum(calabi_zram_mm_orig_data_size{host=~\"$host\"})", "legendFormat": "compression ratio"}
      ]
    },

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 22},
      "id": 103,
      "title": "CPU",
      "type": "row"
    },

    {
      "type": "timeseries",
      "id": 30,
      "title": "Host CPU Usage",
      "gridPos": {"h": 8, "w": 16, "x": 0, "y": 23},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {"lineWidth": 1, "fillOpacity": 10, "stacking": {"mode": "none"}}
        }
      },
      "targets": [
        {
          "expr": "rate(calabi_host_cpu_user_ticks{host=~\"$host\"}[$__rate_interval]) / (rate(calabi_host_cpu_user_ticks{host=~\"$host\"}[$__rate_interval]) + rate(calabi_host_cpu_nice_ticks{host=~\"$host\"}[$__rate_interval]) + rate(calabi_host_cpu_system_ticks{host=~\"$host\"}[$__rate_interval]) + rate(calabi_host_cpu_idle_ticks{host=~\"$host\"}[$__rate_interval]) + rate(calabi_host_cpu_iowait_ticks{host=~\"$host\"}[$__rate_interval]) + rate(calabi_host_cpu_irq_ticks{host=~\"$host\"}[$__rate_interval]) + rate(calabi_host_cpu_softirq_ticks{host=~\"$host\"}[$__rate_interval]) + rate(calabi_host_cpu_steal_ticks{host=~\"$host\"}[$__rate_interval]))",
          "legendFormat": "user"
        },
        {
          "expr": "rate(calabi_host_cpu_system_ticks{host=~\"$host\"}[$__rate_interval]) / (rate(calabi_host_cpu_user_ticks{host=~\"$host\"}[$__rate_interval]) + rate(calabi_host_cpu_nice_ticks{host=~\"$host\"}[$__rate_interval]) + rate(calabi_host_cpu_system_ticks{host=~\"$host\"}[$__rate_interval]) + rate(calabi_host_cpu_idle_ticks{host=~\"$host\"}[$__rate_interval]) + rate(calabi_host_cpu_iowait_ticks{host=~\"$host\"}[$__rate_interval]) + rate(calabi_host_cpu_irq_ticks{host=~\"$host\"}[$__rate_interval]) + rate(calabi_host_cpu_softirq_ticks{host=~\"$host\"}[$__rate_interval]) + rate(calabi_host_cpu_steal_ticks{host=~\"$host\"}[$__rate_interval]))",
          "legendFormat": "system"
        },
        {
          "expr": "rate(calabi_host_cpu_iowait_ticks{host=~\"$host\"}[$__rate_interval]) / (rate(calabi_host_cpu_user_ticks{host=~\"$host\"}[$__rate_interval]) + rate(calabi_host_cpu_nice_ticks{host=~\"$host\"}[$__rate_interval]) + rate(calabi_host_cpu_system_ticks{host=~\"$host\"}[$__rate_interval]) + rate(calabi_host_cpu_idle_ticks{host=~\"$host\"}[$__rate_interval]) + rate(calabi_host_cpu_iowait_ticks{host=~\"$host\"}[$__rate_interval]) + rate(calabi_host_cpu_irq_ticks{host=~\"$host\"}[$__rate_interval]) + rate(calabi_host_cpu_softirq_ticks{host=~\"$host\"}[$__rate_interval]) + rate(calabi_host_cpu_steal_ticks{host=~\"$host\"}[$__rate_interval]))",
          "legendFormat": "iowait"
        },
        {
          "expr": "rate(calabi_host_cpu_steal_ticks{host=~\"$host\"}[$__rate_interval]) / (rate(calabi_host_cpu_user_ticks{host=~\"$host\"}[$__rate_interval]) + rate(calabi_host_cpu_nice_ticks{host=~\"$host\"}[$__rate_interval]) + rate(calabi_host_cpu_system_ticks{host=~\"$host\"}[$__rate_interval]) + rate(calabi_host_cpu_idle_ticks{host=~\"$host\"}[$__rate_interval]) + rate(calabi_host_cpu_iowait_ticks{host=~\"$host\"}[$__rate_interval]) + rate(calabi_host_cpu_irq_ticks{host=~\"$host\"}[$__rate_interval]) + rate(calabi_host_cpu_softirq_ticks{host=~\"$host\"}[$__rate_interval]) + rate(calabi_host_cpu_steal_ticks{host=~\"$host\"}[$__rate_interval]))",
          "legendFormat": "steal"
        },
        {
          "expr": "rate(calabi_host_cpu_idle_ticks{host=~\"$host\"}[$__rate_interval]) / (rate(calabi_host_cpu_user_ticks{host=~\"$host\"}[$__rate_interval]) + rate(calabi_host_cpu_nice_ticks{host=~\"$host\"}[$__rate_interval]) + rate(calabi_host_cpu_system_ticks{host=~\"$host\"}[$__rate_interval]) + rate(calabi_host_cpu_idle_ticks{host=~\"$host\"}[$__rate_interval]) + rate(calabi_host_cpu_iowait_ticks{host=~\"$host\"}[$__rate_interval]) + rate(calabi_host_cpu_irq_ticks{host=~\"$host\"}[$__rate_interval]) + rate(calabi_host_cpu_softirq_ticks{host=~\"$host\"}[$__rate_interval]) + rate(calabi_host_cpu_steal_ticks{host=~\"$host\"}[$__rate_interval]))",
          "legendFormat": "idle"
        }
      ]
    },

    {
      "type": "timeseries",
      "id": 31,
      "title": "Memory Mgmt Thread CPU",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 23},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "custom": {"lineWidth": 1, "fillOpacity": 10}
        }
      },
      "targets": [
        {"expr": "rate(calabi_kernel_thread_cpu_seconds{host=~\"$host\"}[$__rate_interval])", "legendFormat": "{{thread}}"}
      ]
    },

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 31},
      "id": 104,
      "title": "Tier Breakdown",
      "type": "row"
    },

    {
      "type": "bargauge",
      "id": 40,
      "title": "Domains per Tier",
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 32},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 5}, {"color": "red", "value": 10}]}
        }
      },
      "targets": [{"expr": "calabi_tier_domain_count{host=~\"$host\"}", "legendFormat": "{{tier}}"}]
    },

    {
      "type": "bargauge",
      "id": 41,
      "title": "vCPUs per Tier",
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 32},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 16}, {"color": "red", "value": 32}]}
        }
      },
      "targets": [{"expr": "calabi_tier_vcpus{host=~\"$host\"}", "legendFormat": "{{tier}}"}]
    },

    {
      "type": "bargauge",
      "id": 42,
      "title": "Memory Committed per Tier",
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 32},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        }
      },
      "targets": [{"expr": "calabi_tier_memory_committed_bytes{host=~\"$host\"}", "legendFormat": "{{tier}}"}]
    },

    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 38},
      "id": 105,
      "title": "Memory Pressure",
      "type": "row"
    },

    {
      "type": "timeseries",
      "id": 50,
      "title": "Page Scan / Reclaim Rates",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 39},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"lineWidth": 1, "fillOpacity": 6}
        }
      },
      "targets": [
        {"expr": "rate(calabi_vmstat_pgscan_kswapd{host=~\"$host\"}[$__rate_interval])", "legendFormat": "pgscan_kswapd"},
        {"expr": "rate(calabi_vmstat_pgscan_direct{host=~\"$host\"}[$__rate_interval])", "legendFormat": "pgscan_direct"},
        {"expr": "rate(calabi_vmstat_pgsteal_kswapd{host=~\"$host\"}[$__rate_interval])", "legendFormat": "pgsteal_kswapd"},
        {"expr": "rate(calabi_vmstat_pgsteal_direct{host=~\"$host\"}[$__rate_interval])", "legendFormat": "pgsteal_direct"},
        {"expr": "rate(calabi_vmstat_pgmajfault{host=~\"$host\"}[$__rate_interval])", "legendFormat": "pgmajfault"}
      ]
    },

    {
      "type": "timeseries",
      "id": 51,
      "title": "Swap In / Out Rate",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 39},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {"lineWidth": 1, "fillOpacity": 10}
        }
      },
      "targets": [
        {"expr": "rate(calabi_vmstat_pswpin{host=~\"$host\"}[$__rate_interval])", "legendFormat": "pswpin (pages/s in)"},
        {"expr": "rate(calabi_vmstat_pswpout{host=~\"$host\"}[$__rate_interval])", "legendFormat": "pswpout (pages/s out)"}
      ]
    }

  ]
}
