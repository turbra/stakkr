      "fieldConfig": {"defaults": {"unit": "percentunit", "decimals": 2, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 0.5}, {"color": "red", "value": 0.8}]}}},
      "targets": [{"expr": "calabi_domain_ksm_merge_density{host=~\"$host\"}", "legendFormat": "{{domain}} ({{tier}})", "instant": true}]
